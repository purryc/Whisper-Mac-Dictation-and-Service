# Copy or edit this file as WhisperCPP_gateway.env for the local Mac-only gateway launcher.

WHISPER_CPP_BINARY="/absolute/path/to/whisper-cli"
WHISPER_CPP_MODEL="/absolute/path/to/ggml-small.bin"

# Optional tuning
WHISPER_CPP_DEFAULT_LANGUAGE="auto"
WHISPER_CPP_HOST="127.0.0.1"
WHISPER_CPP_PORT="8765"
WHISPER_CPP_PARTIAL_STEP_MS="700"
WHISPER_CPP_MIN_PARTIAL_MS="1600"
